{
  "name": "badwars-site",
  "version": "2.0.1",
  "private": true,
  "description": "BadWars website, dashboard, download center, and Roblox update status API.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-next.mjs",
    "lint": "eslint . --max-warnings=0",
